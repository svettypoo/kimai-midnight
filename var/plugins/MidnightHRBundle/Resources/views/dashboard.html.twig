{% extends 'base.html.twig' %}

{% block title %}HR Dashboard{% endblock %}

{% block main %}
<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-0"><i class="fas fa-briefcase"></i> HR Dashboard — {{ year }}</h2>
        </div>
    </div>

    {# Stats Cards #}
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #0EA5E9, #06B6D4);">
                <div class="card-body text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50 mb-1">Vacation Remaining</h6>
                            <h2 class="mb-0">{{ vacationRemaining }} <small class="fs-6">/ {{ vacationTotal }} days</small></h2>
                        </div>
                        <div style="font-size: 2.5rem; opacity: 0.5;">
                            <i class="fas fa-umbrella-beach"></i>
                        </div>
                    </div>
                    <div class="progress mt-3" style="height: 6px; background: rgba(255,255,255,0.2);">
                        {% set pct = vacationTotal > 0 ? ((vacationUsed / vacationTotal) * 100) : 0 %}
                        <div class="progress-bar bg-white" style="width: {{ pct }}%"></div>
                    </div>
                    <small class="text-white-50">{{ vacationUsed }} days used</small>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #6366F1, #818CF8);">
                <div class="card-body text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50 mb-1">Sick Days Used</h6>
                            <h2 class="mb-0">{{ sickDaysUsed }} <small class="fs-6">days</small></h2>
                        </div>
                        <div style="font-size: 2.5rem; opacity: 0.5;">
                            <i class="fas fa-thermometer-half"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #F59E0B, #FBBF24);">
                <div class="card-body text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50 mb-1">Contract Hours</h6>
                            <h2 class="mb-0">
                                {% if contract %}
                                    {{ contract.hoursPerWeek }} <small class="fs-6">hrs/week</small>
                                {% else %}
                                    N/A
                                {% endif %}
                            </h2>
                        </div>
                        <div style="font-size: 2.5rem; opacity: 0.5;">
                            <i class="fas fa-clock"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        {# Pending Approval Requests #}
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-hourglass-half text-warning"></i> Pending Requests</h5>
                    <span class="badge bg-warning text-dark">{{ pendingAbsences|length }}</span>
                </div>
                <div class="card-body p-0">
                    {% if pendingAbsences|length == 0 %}
                        <div class="text-muted text-center py-4">No pending requests</div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Employee</th>
                                        <th>Type</th>
                                        <th>Dates</th>
                                        <th>Days</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for absence in pendingAbsences %}
                                    <tr>
                                        <td>{{ absence.user.displayName }}</td>
                                        <td>
                                            <span class="badge bg-info">{{ absence.type|capitalize }}</span>
                                        </td>
                                        <td>{{ absence.startDate|date('M d') }} — {{ absence.endDate|date('M d') }}</td>
                                        <td>{{ absence.businessDays }}</td>
                                        <td>
                                            <form method="post" action="{{ path('hr_absence_approve', {id: absence.id}) }}" style="display: inline;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('absence_approve') }}">
                                                <button type="submit" class="btn btn-sm btn-success"><i class="fas fa-check"></i></button>
                                            </form>
                                            <form method="post" action="{{ path('hr_absence_deny', {id: absence.id}) }}" style="display: inline;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('absence_deny') }}">
                                                <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-times"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Upcoming Public Holidays #}
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent">
                    <h5 class="mb-0"><i class="fas fa-calendar-day text-success"></i> Upcoming Holidays</h5>
                </div>
                <div class="card-body p-0">
                    {% if upcomingHolidays|length == 0 %}
                        <div class="text-muted text-center py-4">No upcoming holidays</div>
                    {% else %}
                        <ul class="list-group list-group-flush">
                            {% for holiday in upcomingHolidays %}
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>{{ holiday.name }}</strong>
                                    {% if holiday.recurring %}<span class="badge bg-secondary ms-1">Recurring</span>{% endif %}
                                </div>
                                <span class="text-muted">{{ holiday.date|date('M d, Y') }}</span>
                            </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# My Recent Absences #}
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-history"></i> My Absences ({{ year }})</h5>
                    <a href="{{ path('hr_absence_new') }}" class="btn btn-sm btn-primary">
                        <i class="fas fa-plus"></i> New Request
                    </a>
                </div>
                <div class="card-body p-0">
                    {% if recentAbsences|length == 0 %}
                        <div class="text-muted text-center py-4">No absences recorded this year</div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Type</th>
                                        <th>Start</th>
                                        <th>End</th>
                                        <th>Days</th>
                                        <th>Half Day</th>
                                        <th>Status</th>
                                        <th>Notes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for absence in recentAbsences %}
                                    <tr>
                                        <td><span class="badge bg-info">{{ absence.type|capitalize }}</span></td>
                                        <td>{{ absence.startDate|date('M d, Y') }}</td>
                                        <td>{{ absence.endDate|date('M d, Y') }}</td>
                                        <td>{{ absence.businessDays }}</td>
                                        <td>{{ absence.halfDay ? 'Yes' : '' }}</td>
                                        <td>
                                            {% if absence.status == 'approved' %}
                                                <span class="badge bg-success">Approved</span>
                                            {% elseif absence.status == 'denied' %}
                                                <span class="badge bg-danger">Denied</span>
                                            {% else %}
                                                <span class="badge bg-warning text-dark">Pending</span>
                                            {% endif %}
                                        </td>
                                        <td>{{ absence.notes|default('-')|truncate(50) }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
