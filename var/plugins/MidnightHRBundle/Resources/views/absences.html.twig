{% extends 'base.html.twig' %}

{% block title %}My Absences{% endblock %}

{% block main %}
<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="mb-0"><i class="fas fa-calendar-minus"></i> My Absences</h2>
            <a href="{{ path('hr_absence_new') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> New Absence Request
            </a>
        </div>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'warning' ? 'warning' : 'danger') }} alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            {% if absences|length == 0 %}
                <div class="text-center py-5">
                    <i class="fas fa-calendar-check fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No absence requests found.</p>
                    <a href="{{ path('hr_absence_new') }}" class="btn btn-outline-primary">
                        Submit your first request
                    </a>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Days</th>
                                <th>Half Day</th>
                                <th>Status</th>
                                <th>Approved By</th>
                                <th>Notes</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for absence in absences %}
                            <tr>
                                <td>
                                    {% if absence.type == 'vacation' %}
                                        <span class="badge bg-primary"><i class="fas fa-umbrella-beach"></i> Vacation</span>
                                    {% elseif absence.type == 'sick' %}
                                        <span class="badge bg-danger"><i class="fas fa-thermometer-half"></i> Sick</span>
                                    {% elseif absence.type == 'public_holiday' %}
                                        <span class="badge bg-success"><i class="fas fa-flag"></i> Holiday</span>
                                    {% elseif absence.type == 'unpaid' %}
                                        <span class="badge bg-secondary"><i class="fas fa-ban"></i> Unpaid</span>
                                    {% else %}
                                        <span class="badge bg-info"><i class="fas fa-question-circle"></i> Other</span>
                                    {% endif %}
                                </td>
                                <td>{{ absence.startDate|date('M d, Y') }}</td>
                                <td>{{ absence.endDate|date('M d, Y') }}</td>
                                <td>{{ absence.businessDays }}</td>
                                <td>{{ absence.halfDay ? 'Yes' : '' }}</td>
                                <td>
                                    {% if absence.status == 'approved' %}
                                        <span class="badge bg-success"><i class="fas fa-check"></i> Approved</span>
                                    {% elseif absence.status == 'denied' %}
                                        <span class="badge bg-danger"><i class="fas fa-times"></i> Denied</span>
                                    {% else %}
                                        <span class="badge bg-warning text-dark"><i class="fas fa-hourglass-half"></i> Pending</span>
                                    {% endif %}
                                </td>
                                <td>{{ absence.approvedBy ? absence.approvedBy.displayName : '-' }}</td>
                                <td>{{ absence.notes|default('-')|truncate(40) }}</td>
                                <td>{{ absence.createdAt|date('M d, Y') }}</td>
                                <td>
                                    {% if absence.status == 'pending' %}
                                        <a href="{{ path('hr_absence_edit', {id: absence.id}) }}" class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form method="post" action="{{ path('hr_absence_delete', {id: absence.id}) }}" style="display: inline;" onsubmit="return confirm('Delete this absence request?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('absence_delete') }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    <div class="mt-3">
        <a href="{{ path('hr_dashboard') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Back to HR Dashboard
        </a>
    </div>
</div>
{% endblock %}
