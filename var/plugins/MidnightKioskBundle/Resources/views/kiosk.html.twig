<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kimai Kiosk — Clock In/Out</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #0a0e1a;
            color: #e2e8f0;
            height: 100vh;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Starfield background */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(1px 1px at 10% 20%, rgba(14,165,233,0.6), transparent),
                radial-gradient(1px 1px at 30% 70%, rgba(6,182,212,0.4), transparent),
                radial-gradient(1px 1px at 50% 10%, rgba(99,102,241,0.5), transparent),
                radial-gradient(1px 1px at 70% 80%, rgba(14,165,233,0.3), transparent),
                radial-gradient(1px 1px at 90% 40%, rgba(6,182,212,0.5), transparent),
                radial-gradient(1px 1px at 15% 90%, rgba(99,102,241,0.4), transparent),
                radial-gradient(1px 1px at 85% 15%, rgba(14,165,233,0.4), transparent),
                radial-gradient(1.5px 1.5px at 25% 45%, rgba(255,255,255,0.3), transparent),
                radial-gradient(1.5px 1.5px at 60% 55%, rgba(255,255,255,0.2), transparent),
                radial-gradient(1.5px 1.5px at 40% 30%, rgba(255,255,255,0.25), transparent),
                radial-gradient(1px 1px at 75% 65%, rgba(255,255,255,0.15), transparent),
                radial-gradient(1px 1px at 5% 50%, rgba(255,255,255,0.2), transparent);
            z-index: 0;
            pointer-events: none;
        }

        .kiosk-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 480px;
            padding: 2rem;
            text-align: center;
        }

        /* Digital Clock */
        .clock-display {
            font-size: 5rem;
            font-weight: 200;
            letter-spacing: 0.1em;
            color: #0EA5E9;
            text-shadow: 0 0 30px rgba(14,165,233,0.4);
            margin-bottom: 0.25rem;
            font-variant-numeric: tabular-nums;
        }

        .clock-date {
            font-size: 1rem;
            color: #64748b;
            margin-bottom: 2rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
        }

        /* Status */
        .status-bar {
            padding: 0.75rem 1.5rem;
            border-radius: 12px;
            font-size: 0.95rem;
            margin-bottom: 2rem;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .status-idle {
            background: rgba(99,102,241,0.15);
            border: 1px solid rgba(99,102,241,0.3);
            color: #818CF8;
        }

        .status-in {
            background: rgba(34,197,94,0.15);
            border: 1px solid rgba(34,197,94,0.3);
            color: #4ade80;
        }

        .status-out {
            background: rgba(239,68,68,0.15);
            border: 1px solid rgba(239,68,68,0.3);
            color: #f87171;
        }

        /* User greeting */
        .user-greeting {
            font-size: 1.5rem;
            font-weight: 300;
            color: #06B6D4;
            margin-bottom: 1.5rem;
            min-height: 2.25rem;
        }

        /* PIN Display */
        .pin-display {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-bottom: 1.5rem;
        }

        .pin-dot {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            border: 2px solid #334155;
            transition: all 0.2s ease;
        }

        .pin-dot.filled {
            background: #0EA5E9;
            border-color: #0EA5E9;
            box-shadow: 0 0 10px rgba(14,165,233,0.5);
        }

        /* Numpad */
        .numpad {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            max-width: 320px;
            margin: 0 auto 2rem;
        }

        .numpad-btn {
            background: rgba(30, 41, 59, 0.6);
            border: 1px solid rgba(51, 65, 85, 0.5);
            border-radius: 16px;
            color: #e2e8f0;
            font-size: 1.75rem;
            font-weight: 300;
            padding: 1rem;
            cursor: pointer;
            transition: all 0.15s ease;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }

        .numpad-btn:hover {
            background: rgba(14, 165, 233, 0.15);
            border-color: rgba(14, 165, 233, 0.4);
            transform: scale(1.05);
        }

        .numpad-btn:active {
            transform: scale(0.95);
            background: rgba(14, 165, 233, 0.25);
        }

        .numpad-btn.action {
            font-size: 1rem;
            font-weight: 500;
            letter-spacing: 0.05em;
        }

        .numpad-btn.clear {
            color: #f87171;
            border-color: rgba(239,68,68,0.3);
        }

        .numpad-btn.clear:hover {
            background: rgba(239,68,68,0.15);
            border-color: rgba(239,68,68,0.5);
        }

        .numpad-btn.enter {
            color: #4ade80;
            border-color: rgba(34,197,94,0.3);
        }

        .numpad-btn.enter:hover {
            background: rgba(34,197,94,0.15);
            border-color: rgba(34,197,94,0.5);
        }

        /* Action buttons */
        .action-buttons {
            display: flex;
            gap: 16px;
            justify-content: center;
        }

        .action-btn {
            padding: 1rem 2.5rem;
            border-radius: 16px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            border: 2px solid transparent;
            letter-spacing: 0.05em;
        }

        .action-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
            transform: none !important;
        }

        .btn-clock-in {
            background: linear-gradient(135deg, #059669, #10b981);
            color: white;
            border-color: #059669;
        }

        .btn-clock-in:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(5,150,105,0.4);
        }

        .btn-clock-out {
            background: linear-gradient(135deg, #dc2626, #ef4444);
            color: white;
            border-color: #dc2626;
        }

        .btn-clock-out:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(220,38,38,0.4);
        }

        /* Message toast */
        .toast-msg {
            position: fixed;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            padding: 1rem 2rem;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 500;
            transition: transform 0.3s ease;
            z-index: 100;
        }

        .toast-msg.show {
            transform: translateX(-50%) translateY(0);
        }

        .toast-msg.success {
            background: rgba(34,197,94,0.2);
            border: 1px solid rgba(34,197,94,0.4);
            color: #4ade80;
        }

        .toast-msg.error {
            background: rgba(239,68,68,0.2);
            border: 1px solid rgba(239,68,68,0.4);
            color: #f87171;
        }

        /* Phases */
        .phase-pin { display: block; }
        .phase-actions { display: none; }

        body.authenticated .phase-pin { display: none; }
        body.authenticated .phase-actions { display: block; }

        /* Logo */
        .logo {
            font-size: 0.85rem;
            color: #334155;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            position: fixed;
            bottom: 1rem;
            left: 50%;
            transform: translateX(-50%);
        }
    </style>
</head>
<body>
    <div class="kiosk-container">
        <div class="clock-display" id="clock">00:00</div>
        <div class="clock-date" id="clockDate">Loading...</div>

        <div class="user-greeting" id="greeting"></div>

        <div id="statusBar" class="status-bar status-idle">
            Enter your PIN to begin
        </div>

        <!-- PIN Entry Phase -->
        <div class="phase-pin">
            <div class="pin-display" id="pinDisplay">
                <div class="pin-dot"></div>
                <div class="pin-dot"></div>
                <div class="pin-dot"></div>
                <div class="pin-dot"></div>
                <div class="pin-dot"></div>
                <div class="pin-dot"></div>
            </div>

            <div class="numpad">
                <button class="numpad-btn" onclick="addDigit('1')">1</button>
                <button class="numpad-btn" onclick="addDigit('2')">2</button>
                <button class="numpad-btn" onclick="addDigit('3')">3</button>
                <button class="numpad-btn" onclick="addDigit('4')">4</button>
                <button class="numpad-btn" onclick="addDigit('5')">5</button>
                <button class="numpad-btn" onclick="addDigit('6')">6</button>
                <button class="numpad-btn" onclick="addDigit('7')">7</button>
                <button class="numpad-btn" onclick="addDigit('8')">8</button>
                <button class="numpad-btn" onclick="addDigit('9')">9</button>
                <button class="numpad-btn action clear" onclick="clearPin()">CLR</button>
                <button class="numpad-btn" onclick="addDigit('0')">0</button>
                <button class="numpad-btn action enter" onclick="submitPin()">OK</button>
            </div>
        </div>

        <!-- Clock In/Out Phase -->
        <div class="phase-actions">
            <div class="action-buttons">
                <button class="action-btn btn-clock-in" id="btnClockIn" onclick="clockIn()">
                    Clock In
                </button>
                <button class="action-btn btn-clock-out" id="btnClockOut" onclick="clockOut()">
                    Clock Out
                </button>
            </div>
        </div>
    </div>

    <div class="toast-msg" id="toast"></div>
    <div class="logo">Kimai Kiosk</div>

    <script>
        let pin = '';
        let currentUser = null;
        let statusInterval = null;
        const MAX_PIN_LENGTH = 6;

        // Clock
        function updateClock() {
            const now = new Date();
            const h = String(now.getHours()).padStart(2, '0');
            const m = String(now.getMinutes()).padStart(2, '0');
            document.getElementById('clock').textContent = h + ':' + m;

            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            document.getElementById('clockDate').textContent = now.toLocaleDateString('en-US', options);
        }
        updateClock();
        setInterval(updateClock, 1000);

        // PIN
        function addDigit(d) {
            if (pin.length >= MAX_PIN_LENGTH) return;
            pin += d;
            updatePinDots();
        }

        function clearPin() {
            pin = '';
            updatePinDots();
            setStatus('Enter your PIN to begin', 'idle');
        }

        function updatePinDots() {
            const dots = document.querySelectorAll('.pin-dot');
            dots.forEach((dot, i) => {
                dot.classList.toggle('filled', i < pin.length);
            });
        }

        async function submitPin() {
            if (pin.length < 4) {
                showToast('PIN must be at least 4 digits', 'error');
                return;
            }

            try {
                const res = await fetch('{{ path("kiosk_verify_pin") }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ pin }),
                });
                const data = await res.json();

                if (data.success) {
                    currentUser = data.user;
                    document.getElementById('greeting').textContent = 'Hello, ' + currentUser.name;
                    document.body.classList.add('authenticated');
                    fetchStatus();
                    statusInterval = setInterval(fetchStatus, 10000);

                    // Auto-logout after 30 seconds of inactivity
                    setTimeout(resetKiosk, 30000);
                } else {
                    showToast(data.message || 'Invalid PIN', 'error');
                    clearPin();
                }
            } catch (e) {
                showToast('Connection error', 'error');
            }
        }

        async function fetchStatus() {
            if (!currentUser) return;
            try {
                const res = await fetch('{{ path("kiosk_status", {userId: "__UID__"}) }}'.replace('__UID__', currentUser.id));
                const data = await res.json();

                if (data.clockedIn) {
                    setStatus('Clocked in since ' + data.since, 'in');
                    document.getElementById('btnClockIn').disabled = true;
                    document.getElementById('btnClockOut').disabled = false;
                } else {
                    setStatus('Not clocked in', 'out');
                    document.getElementById('btnClockIn').disabled = false;
                    document.getElementById('btnClockOut').disabled = true;
                }
            } catch (e) {
                console.error('Status fetch failed', e);
            }
        }

        async function clockIn() {
            if (!currentUser) return;
            try {
                const res = await fetch('{{ path("kiosk_clock_in") }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId: currentUser.id }),
                });
                const data = await res.json();

                if (data.success) {
                    showToast(data.message, 'success');
                    fetchStatus();
                } else {
                    showToast(data.message || 'Clock in failed', 'error');
                }
            } catch (e) {
                showToast('Connection error', 'error');
            }
        }

        async function clockOut() {
            if (!currentUser) return;
            try {
                const res = await fetch('{{ path("kiosk_clock_out") }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId: currentUser.id }),
                });
                const data = await res.json();

                if (data.success) {
                    showToast(data.message, 'success');
                    fetchStatus();
                    setTimeout(resetKiosk, 3000);
                } else {
                    showToast(data.message || 'Clock out failed', 'error');
                }
            } catch (e) {
                showToast('Connection error', 'error');
            }
        }

        function resetKiosk() {
            currentUser = null;
            pin = '';
            updatePinDots();
            document.body.classList.remove('authenticated');
            document.getElementById('greeting').textContent = '';
            setStatus('Enter your PIN to begin', 'idle');
            if (statusInterval) {
                clearInterval(statusInterval);
                statusInterval = null;
            }
        }

        function setStatus(text, type) {
            const bar = document.getElementById('statusBar');
            bar.textContent = text;
            bar.className = 'status-bar status-' + type;
        }

        function showToast(msg, type) {
            const toast = document.getElementById('toast');
            toast.textContent = msg;
            toast.className = 'toast-msg ' + type + ' show';
            setTimeout(() => { toast.classList.remove('show'); }, 3000);
        }
    </script>
</body>
</html>
