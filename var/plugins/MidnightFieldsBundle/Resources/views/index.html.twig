{% extends 'base.html.twig' %}

{% block page_title %}Custom Fields{% endblock %}

{% block page_actions %}
    <a href="{{ path('midnight_fields_create') }}" class="btn btn-primary">
        <i class="fas fa-plus"></i> New Field
    </a>
{% endblock %}

{% block main %}
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Custom Field Definitions</h3>
            </div>
            <div class="card-body p-0">
                <ul class="nav nav-tabs" id="entityTabs" role="tablist">
                    {% for type in entity_types %}
                        <li class="nav-item" role="presentation">
                            <button class="nav-link {{ loop.first ? 'active' : '' }}"
                                    id="tab-{{ type }}"
                                    data-bs-toggle="tab"
                                    data-bs-target="#pane-{{ type }}"
                                    type="button"
                                    role="tab"
                                    aria-controls="pane-{{ type }}"
                                    aria-selected="{{ loop.first ? 'true' : 'false' }}">
                                {{ type|capitalize }}
                                <span class="badge bg-secondary ms-1">{{ grouped[type]|length }}</span>
                            </button>
                        </li>
                    {% endfor %}
                </ul>

                <div class="tab-content" id="entityTabContent">
                    {% for type in entity_types %}
                        <div class="tab-pane fade {{ loop.first ? 'show active' : '' }}"
                             id="pane-{{ type }}"
                             role="tabpanel"
                             aria-labelledby="tab-{{ type }}">

                            {% if grouped[type] is empty %}
                                <div class="text-center text-muted py-4">
                                    No custom fields defined for {{ type|capitalize }}.
                                    <br>
                                    <a href="{{ path('midnight_fields_create', {entity_type: type}) }}" class="btn btn-sm btn-outline-primary mt-2">
                                        <i class="fas fa-plus"></i> Add one
                                    </a>
                                </div>
                            {% else %}
                                <form action="{{ path('midnight_fields_reorder') }}" method="post">
                                    <table class="table table-hover table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th style="width: 60px;">Order</th>
                                                <th>Label</th>
                                                <th>Key</th>
                                                <th>Type</th>
                                                <th style="width: 80px;">Required</th>
                                                <th style="width: 80px;">Visible</th>
                                                <th style="width: 140px;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for definition in grouped[type] %}
                                                <tr>
                                                    <td>
                                                        <input type="number"
                                                               name="positions[{{ definition.id }}]"
                                                               value="{{ definition.position }}"
                                                               class="form-control form-control-sm"
                                                               style="width: 60px;"
                                                               min="0">
                                                    </td>
                                                    <td>{{ definition.name }}</td>
                                                    <td><code>{{ definition.fieldKey }}</code></td>
                                                    <td>
                                                        <span class="badge bg-info">{{ definition.fieldType }}</span>
                                                    </td>
                                                    <td>
                                                        {% if definition.required %}
                                                            <span class="badge bg-danger">Yes</span>
                                                        {% else %}
                                                            <span class="text-muted">No</span>
                                                        {% endif %}
                                                    </td>
                                                    <td>
                                                        {% if definition.visible %}
                                                            <span class="badge bg-success">Yes</span>
                                                        {% else %}
                                                            <span class="badge bg-secondary">Hidden</span>
                                                        {% endif %}
                                                    </td>
                                                    <td>
                                                        <a href="{{ path('midnight_fields_edit', {id: definition.id}) }}"
                                                           class="btn btn-sm btn-outline-primary"
                                                           title="Edit">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                        <form action="{{ path('midnight_fields_delete', {id: definition.id}) }}"
                                                              method="post"
                                                              style="display: inline-block;"
                                                              onsubmit="return confirm('Delete this custom field? All stored values will be lost.');">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ definition.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                    <div class="card-footer text-end">
                                        <button type="submit" class="btn btn-sm btn-success">
                                            <i class="fas fa-sort"></i> Save Order
                                        </button>
                                    </div>
                                </form>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
